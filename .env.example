# ─────────────────────────────────────────────────────────
# Mwango Sheria — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# Waitlist API endpoint (Vercel serverless function or external service)
# VITE_WAITLIST_API_URL=https://your-domain.vercel.app/api/waitlist

# Analytics (optional)
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://app.posthog.com
